{
  "name": "basketcase-react",
  "description": "Mock online store app selling washing machines with faceted navigation built using React, Serverless Framework and Elasticsearch",
  "private": true,
  "version": "0.0.44",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run --reporter verbose",
    "test:cypress": "cypress run",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "predeploy": "npm run build",
    "open": "open https://taylorjg.github.io/basketcase-react"
  },
  "dependencies": {
    "@ahooksjs/use-url-state": "^3.5.1",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@fontsource/roboto": "^5.0.3",
    "@mui/icons-material": "^5.11.16",
    "@mui/material": "^5.13.5",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.4.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/cypress": "^9.0.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/react": "^18.0.37",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/eslint-plugin": "^1.6.21",
    "cypress": "^12.15.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.4.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "gh-pages": "^5.0.0",
    "globals": "^17.7.0",
    "jsdom": "^26.1.0",
    "msw": "^2.14.6",
    "prettier": "^3.9.4",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "react-router": "$react-router-dom"
  }
